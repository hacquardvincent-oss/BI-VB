# Copier en .env pour le développement local (ne JAMAIS committer .env)

# Connexion PostgreSQL — OPTIONNELLE.
#  • Absente  → l'app tourne en mémoire (fichiers re-déposés à chaque démarrage).
#  • Présente → persistance des fichiers déposés, des objectifs et des comptes équipe.
# Neon (gratuit) : créer un projet sur neon.tech puis coller la "connection string".
# Neon impose TLS (gardé par défaut). En local, ajouter ?sslmode=disable.
# DATABASE_URL=postgresql://user:pass@ep-xxx.eu-central-1.aws.neon.tech/bidash?sslmode=require

# Secret de session (chaîne aléatoire longue en production)
SESSION_SECRET=dev-secret-a-changer

# Compte admin initial (créé au premier démarrage s'il n'existe pas)
ADMIN_USERNAME=Vincent
# Mot de passe admin : à définir ici en local et dans les variables d'env Render.
# NE PAS committer une vraie valeur. (mot de passe faible = à changer rapidement)
ADMIN_PASSWORD=change-me

# Port HTTP local
PORT=3000

# Connecteur WSHOP (optionnel — source OMS via API ; cf. server/wshop.js)
# Auth OK (login → JWT 1h). Endpoint commandes + mapping JSON encore à finaliser.
# WSHOP_INSTANCE=              # instance attribuée par WSHOP → base https://{instance}.wshop.cloud
# WSHOP_USER=                  # email de connexion
# WSHOP_PWD=                   # mot de passe
# WSHOP_PREPROD=               # "1" pour viser la préproduction
# WSHOP_MONTHS=24              # profondeur d'historique importé (mois)
# WSHOP_API_BASE=              # (optionnel) override direct de la base

# Moteur de recommandations stratégiques (optionnel — API Claude ; cf. server/reco.js)
# ANTHROPIC_API_KEY=          # clé API Anthropic (active le bouton « Recommandations »)
# ANTHROPIC_MODEL=claude-opus-4-8   # modèle (défaut : claude-opus-4-8)

# Connecteur GA4 (optionnel — cf. ADR-007)
# Property ID numérique de la propriété GA4
GA4_PROPERTY_ID=358326945
# Clé du service account : soit GA4_SA_KEY (JSON ou base64 du JSON),
# soit un fichier monté (Render Secret File) lu via /etc/secrets/ga4.json
# GA4_SA_KEY=


# Connecteur Y2 (optionnel — ERP/Marketplace via base PostgreSQL ; cf. server/y2.js)
# Connexion directe à la base Y2 → charge le jeu `y2` (N/N-1), avec anti-PII.
# Y2_DATABASE_URL=postgres://user:pwd@host:5432/base   # OU Y2_PGHOST/Y2_PGPORT/Y2_PGUSER/Y2_PGPASSWORD/Y2_PGDATABASE
# Y2_SSL=                       # "disable" pour couper TLS (défaut : TLS activé)
# Requête renvoyant les colonnes Y2 ($1=début, $2=fin, dates ISO). Aliasez aux noms attendus :
#   "Etablissement" "Total TTC ligne" "Commercial" "Reference interne" "Code article" "LIBDIM2" "Quantite" "Date"
# Y2_QUERY=SELECT total_ttc AS "Total TTC ligne", etablissement AS "Etablissement", commercial AS "Commercial", ref_interne AS "Reference interne", code_article AS "Code article", libdim2 AS "LIBDIM2", quantite AS "Quantite", date_vente AS "Date" FROM ventes WHERE date_vente BETWEEN $1::date AND $2::date
# Y2_QUERY_N1=                  # (optionnel) requête distincte pour N-1 ; défaut = Y2_QUERY sur la fenêtre N-1
