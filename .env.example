# Copier en .env pour le développement local (ne JAMAIS committer .env)

# Connexion PostgreSQL — OPTIONNELLE.
#  • Absente  → l'app tourne en mémoire (fichiers re-déposés à chaque démarrage).
#  • Présente → persistance des fichiers déposés, des objectifs et des comptes équipe.
# Neon (gratuit) : créer un projet sur neon.tech puis coller la "connection string".
# Neon impose TLS (gardé par défaut). En local, ajouter ?sslmode=disable.
# DATABASE_URL=postgresql://user:pass@ep-xxx.eu-central-1.aws.neon.tech/bidash?sslmode=require

# Secret de session (chaîne aléatoire longue en production)
SESSION_SECRET=dev-secret-a-changer

# Compte admin initial (créé au premier démarrage s'il n'existe pas)
ADMIN_USERNAME=Vincent
# Mot de passe admin : à définir ici en local et dans les variables d'env Render.
# NE PAS committer une vraie valeur. (mot de passe faible = à changer rapidement)
ADMIN_PASSWORD=change-me

# Port HTTP local
PORT=3000

# Connecteur GA4 (optionnel — cf. ADR-007)
# Property ID numérique de la propriété GA4
GA4_PROPERTY_ID=358326945
# Clé du service account : soit GA4_SA_KEY (JSON ou base64 du JSON),
# soit un fichier monté (Render Secret File) lu via /etc/secrets/ga4.json
# GA4_SA_KEY=

